# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# --- Cloudinary (project screenshots / media) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Contact form email delivery (used by app/api/contact/route.ts) ---
CONTACT_EMAIL_TO=
RESEND_API_KEY=

# --- Analytics ---
NEXT_PUBLIC_ANALYTICS_ID=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://princenarula.dev
